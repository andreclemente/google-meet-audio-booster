{
  "manifest_version": 3,
  "name": "Meet Audio Booster",
  "version": "1.0.2",
  "description": "Per-participant volume controls for Google Meet and Jitsi Meet.",
  "host_permissions": [
    "https://meet.google.com/*",
    "https://meet.jit.si/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://meet.google.com/*",
        "https://meet.jit.si/*"
      ],
      "js": [
        "audio-booster.js"
      ],
      "run_at": "document_start",
      "world": "MAIN"
    }
  ]
}
